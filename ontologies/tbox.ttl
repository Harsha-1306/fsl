@prefix : <http://www.softlang.org/ontologies/tbox#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.softlang.org/ontologies/tbox> a owl:Ontology ;
    :commentingPolicy "All rdfs:comments must start in upper case."@en ;
    :formattingPolicy "TTL syntax is to be used so that triples are grouped by shared subject. Default namespace (\":\") instead of explicit prefixes should be used, whenever possible. The required order in ontology files is: prefix declarations first, followed by the ontology header, then classes ordered by class name, then properties ordered by property name, and finally all remaining assertions ordered by subject name. Any serialization of the ontology should obey this formatting policy."@en ;
    :metamodelingPolicy "Punning/metamodeling is used systematically. Every class that is a subclass of an Entity subclass should also be explicitly typed as that Entity subclass. Every individual whose asserted type derives from an Entity subclass should also be explicitly typed as that Entity subclass. Example: le:QueryLanguage a tbox:LanguageEntity . Example: le:SQL a tbox:LanguageEntity . This expectation should be maintained as the ontology evolves."@en ;
    rdfs:comment "Shared TBox of the FSL ontology"@en .

:ArtifactEntity rdfs:label "Artifact entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from ArtifactEntity explicitly as an ArtifactEntity."@en ;
    rdfs:comment "Ontological entity used to represent software artifacts, artifact families, and artifact-related instances"@en ;
    rdfs:subClassOf :Entity .

:Assertion a :ConceptualEntity,
        owl:Class ;
    rdfs:label "Assertion"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from Assertion explicitly as a ConceptualEntity."@en ;
    rdfs:comment "Reified assertion entity used for qualified statements in language-related modules"@en ;
    rdfs:subClassOf :ConceptualEntity .

:ConceptualEntity rdfs:label "Conceptual entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from ConceptualEntity explicitly as a ConceptualEntity."@en ;
    rdfs:comment "Contextual concepts for the primary entity types (foundations, languages, tools, and artifacts)"@en ;
    rdfs:subClassOf :Entity .

:Entity a owl:Class ;
    rdfs:label "Entity"@en ;
    rdfs:comment "Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty foaf:isPrimaryTopicOf ;
                        owl:someValuesFrom foaf:Document ] [ a owl:Restriction ;
                        owl:onProperty foaf:page ;
                        owl:someValuesFrom foaf:Document ] ) ] .

:FoundationalEntity rdfs:label "Foundational entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from FoundationalEntity explicitly as a FoundationalEntity."@en ;
    rdfs:comment "Ontological entity used to represent foundational formalisms, theories, models of computation, and methodological approaches"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty :hasArea ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty :hasArea ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:TechnologicalSpace ;
            owl:onProperty :hasSpace ],
        :Entity .

:IssueEntity a :Entity,
        owl:Class ;
    rdfs:label "Issue entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from IssueEntity explicitly as an Entity."@en ;
    rdfs:comment "Entity for representing review issues, critiques, and proposed resolutions concerning resources, predicates, or fully specified assertions in the ontology"@en ;
    rdfs:subClassOf :Entity .

:LanguageEntity rdfs:label "Language entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from LanguageEntity explicitly as a LanguageEntity."@en ;
    rdfs:comment "Ontological entity used to represent software languages, language families, and language-related instances"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty :hasArea ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:TechnologicalSpace ;
            owl:onProperty :hasSpace ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty :hasArea ],
        :Entity .

:ReferenceEntity a owl:Class ;
    rdfs:label "Reference entity"@en ;
    rdfs:comment "Reference entities are essentially literature references with properties inspired by the BIB format."@en ;
    rdfs:subClassOf :Entity .

:SoftwareArtifact a :ArtifactEntity ;
    rdfs:label "Software artifact"@en ;
    rdfs:comment "Software artifact kind used to classify the characteristic artifacts of a technological space"@en ;
    rdfs:subClassOf :ArtifactEntity .

:SoftwareLanguage a :LanguageEntity ;
    rdfs:label "Software language"@en ;
    rdfs:comment "Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages."@en ;
    rdfs:subClassOf :LanguageEntity ;
    foaf:page <https://en.wikipedia.org/wiki/Software_language> .

:SoftwareTool a :ToolEntity ;
    rdfs:label "Software tool"@en ;
    rdfs:subClassOf :ToolEntity .

:ToolEntity rdfs:label "Tool entity"@en ;
    :metamodelingPolicy "Declare every subclass and every individual derived from ToolEntity explicitly as a ToolEntity."@en ;
    rdfs:comment "Ontological entity used to represent software tools, tool families, and tool-related instances"@en ;
    rdfs:subClassOf :Entity .

:classifies a owl:ObjectProperty ;
    rdfs:label "classifies"@en ;
    rdfs:comment "Relates an artifact entity to another artifact entity that conforms to it as its classifier, schema, metamodel, or analogous defining artifact"@en ;
    rdfs:domain :ArtifactEntity ;
    rdfs:range :ArtifactEntity ;
    owl:inverseOf :conformsTo .

:commentingPolicy a owl:AnnotationProperty ;
    rdfs:label "Commenting policy"@en ;
    rdfs:comment "Documents the ontology-wide expectation regarding commenting"@en .

:conformsTo a owl:ObjectProperty ;
    rdfs:label "conforms to"@en ;
    rdfs:comment "Relates an artifact entity to another artifact entity that classifies it through a meta-to-metamodel-like conformance relation across technological spaces"@en ;
    rdfs:domain :ArtifactEntity ;
    rdfs:range :ArtifactEntity ;
    owl:inverseOf :classifies .

:critique a owl:DatatypeProperty ;
    rdfs:label "critique"@en ;
    rdfs:comment "Describes the problem, concern, or critique expressed by an issue"@en ;
    rdfs:domain :IssueEntity ;
    rdfs:range xsd:string .

:elementOf a owl:ObjectProperty ;
    rdfs:label "element of"@en ;
    rdfs:domain :ArtifactEntity ;
    rdfs:range :LanguageEntity ;
    owl:inverseOf :hasElement .

:extends a owl:ObjectProperty ;
    rdfs:label "extends"@en ;
    rdfs:comment "Relates a software language to another software language that it extends or generalizes"@en ;
    rdfs:domain :SoftwareLanguage ;
    rdfs:range :SoftwareLanguage ;
    owl:inverseOf :isExtendedBy .

:formattingPolicy a owl:AnnotationProperty ;
    rdfs:label "Formatting policy"@en ;
    rdfs:comment "Documents the ontology-wide expectation regarding formatting"@en .

:hasAffectedArtifact a owl:ObjectProperty ;
    rdfs:label "has affected artifact"@en ;
    rdfs:comment "Relates a software engineering activity or software tool to an artifact kind that it characteristically affects or modifies when the role is not best captured as input or output alone"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity :ToolEntity ) ] ;
    rdfs:range :ArtifactEntity .

:hasArea a owl:ObjectProperty ;
    rdfs:label "has area"@en ;
    rdfs:comment "Identifies an important subject area of interest for an entity"@en ;
    rdfs:domain :Entity ;
    rdfs:range ce:SubjectArea ;
    owl:inverseOf :isAreaOf .

:hasArtifact a owl:ObjectProperty ;
    rdfs:label "has artifact"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range :ArtifactEntity ;
    owl:inverseOf :isArtifactOf .

:hasAuthorString a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasBibtexKey a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasBooktitle a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasDOI a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasElement a owl:ObjectProperty ;
    rdfs:label "has element"@en ;
    rdfs:domain :LanguageEntity ;
    rdfs:range :ArtifactEntity ;
    owl:inverseOf :elementOf .

:hasEntryType a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasInclusionRoleComment a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasInputArtifact a owl:ObjectProperty ;
    rdfs:label "has input artifact"@en ;
    rdfs:comment "Relates a software engineering activity or software tool to an artifact kind that it typically requires or consumes as input"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity :ToolEntity ) ] ;
    rdfs:range :ArtifactEntity .

:hasJournal a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasNumber a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasOutputArtifact a owl:ObjectProperty ;
    rdfs:label "has output artifact"@en ;
    rdfs:comment "Relates a software engineering activity or software tool to an artifact kind that it typically produces as output"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity :ToolEntity ) ] ;
    rdfs:range :ArtifactEntity .

:hasPages a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasPart a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment "Relates an ontology entity to another ontology entity that is a structural part or constituent of it"@en ;
    rdfs:domain :Entity ;
    rdfs:range :Entity ;
    rdfs:subPropertyOf :uses ;
    owl:inverseOf :isPartOf .

:hasPublicationYear a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:gYear .

:hasPublisher a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasReference a owl:ObjectProperty ;
    rdfs:label "has reference"@en ;
    rdfs:comment "Relates an entity to a reference entity that documents, discusses, or supports it"@en ;
    rdfs:domain :Entity ;
    rdfs:range :ReferenceEntity ;
    owl:inverseOf :isReferenceFor .

:hasSeries a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasSpace a owl:ObjectProperty ;
    rdfs:label "has space"@en ;
    rdfs:comment "Associates an entity with a technological space to which it characteristically belongs"@en ;
    rdfs:domain :Entity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf :isSpaceOf .

:hasSupportingLanguage a owl:ObjectProperty ;
    rdfs:label "has supporting language"@en ;
    rdfs:comment "Relates a software engineering activity to a language kind that is characteristically used to perform or express the activity"@en ;
    rdfs:domain ce:EngineeringActivity ;
    rdfs:range :LanguageEntity .

:hasSupportingTool a owl:ObjectProperty ;
    rdfs:label "has supporting tool"@en ;
    rdfs:comment "Relates a software engineering activity to a tool kind that characteristically supports carrying out the activity"@en ;
    rdfs:domain ce:EngineeringActivity ;
    rdfs:range :ToolEntity .

:hasTitle a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:hasTool a owl:ObjectProperty ;
    rdfs:label "has tool"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range :ToolEntity ;
    owl:inverseOf :isToolOf .

:hasURL a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:anyURI .

:hasVolume a owl:DatatypeProperty ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range xsd:string .

:isAreaOf a owl:ObjectProperty ;
    rdfs:label "is area of"@en ;
    rdfs:comment "Relates a subject area to an entity for which it is an important area of interest"@en ;
    rdfs:domain ce:SubjectArea ;
    rdfs:range :Entity ;
    owl:inverseOf :hasArea .

:isArtifactOf a owl:ObjectProperty ;
    rdfs:label "is artifact of"@en ;
    rdfs:domain :ArtifactEntity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf :hasArtifact .

:isExtendedBy a owl:ObjectProperty ;
    rdfs:label "is extended by"@en ;
    rdfs:comment "Relates a software language to another software language that extends or generalizes it"@en ;
    rdfs:domain :SoftwareLanguage ;
    rdfs:range :SoftwareLanguage ;
    owl:inverseOf :extends .

:isPartOf a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Relates an ontology entity to another ontology entity of which it is a structural part or constituent"@en ;
    rdfs:domain :Entity ;
    rdfs:range :Entity ;
    rdfs:subPropertyOf :isUsedBy ;
    owl:inverseOf :hasPart .

:isProcessedBy a owl:ObjectProperty ;
    rdfs:label "is processed by"@en ;
    rdfs:comment "Relates an artifact entity to a tool entity that characteristically processes it"@en ;
    rdfs:domain :ArtifactEntity ;
    rdfs:range :ToolEntity ;
    owl:inverseOf :processes .

:isReferenceFor a owl:ObjectProperty ;
    rdfs:label "is reference for"@en ;
    rdfs:comment "Relates a reference entity to an entity that it documents, discusses, or supports"@en ;
    rdfs:domain :ReferenceEntity ;
    rdfs:range :Entity ;
    owl:inverseOf :hasReference .

:isServedBy a owl:ObjectProperty ;
    rdfs:label "is served by"@en ;
    rdfs:comment "Relates a methodological approach to an entity that serves, realizes, supports, or instantiates it in an important way"@en ;
    rdfs:domain fe:MethodologicalApproach ;
    rdfs:range :Entity ;
    owl:inverseOf :serves .

:isSpaceOf a owl:ObjectProperty ;
    rdfs:label "is space of"@en ;
    rdfs:comment "Relates a technological space to an entity that characteristically belongs to it"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range :Entity ;
    owl:inverseOf :hasSpace .

:isSpecifiedBy a owl:ObjectProperty ;
    rdfs:label "is specified by"@en ;
    rdfs:comment "Relates an entity to a methodological approach used to formally specify or define its behavior or meaning"@en ;
    rdfs:domain :FoundationalEntity ;
    rdfs:range fe:MethodologicalApproach ;
    owl:inverseOf :specifies .

:isSupportedBy a owl:ObjectProperty ;
    rdfs:label "is supported by"@en ;
    rdfs:comment "Relates a language entity to a tool entity that supports it"@en ;
    rdfs:domain :LanguageEntity ;
    rdfs:range :ToolEntity ;
    owl:inverseOf :supports .

:isToolOf a owl:ObjectProperty ;
    rdfs:label "is tool of"@en ;
    rdfs:domain :ToolEntity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf :hasTool .

:isUsedBy a owl:ObjectProperty ;
    rdfs:label "is used by"@en ;
    rdfs:comment "Relates an ontology entity to another ontology entity that uses it conceptually, methodologically, or technically"@en ;
    rdfs:domain :Entity ;
    rdfs:range :Entity ;
    owl:inverseOf :uses .

:metamodelingPolicy a owl:AnnotationProperty ;
    rdfs:label "Metamodeling policy"@en ;
    rdfs:comment "Documents the ontology-wide expectation for explicit punning-based typing of classes and individuals with the corresponding Entity subclass"@en .

:processes a owl:ObjectProperty ;
    rdfs:label "processes"@en ;
    rdfs:comment "Relates a tool entity to an artifact entity that it characteristically processes"@en ;
    rdfs:domain :ToolEntity ;
    rdfs:range :ArtifactEntity ;
    owl:inverseOf :isProcessedBy .

:serves a owl:ObjectProperty ;
    rdfs:label "serves"@en ;
    rdfs:comment "Relates an entity to a methodological approach that it serves, realizes, supports, or instantiates in an important way"@en ;
    rdfs:domain :Entity ;
    rdfs:range fe:MethodologicalApproach ;
    owl:inverseOf :isServedBy .

:specifies a owl:ObjectProperty ;
    rdfs:label "specifies"@en ;
    rdfs:comment "Relates a methodological approach to an entity whose behavior or meaning it is used to formally specify or define"@en ;
    rdfs:domain fe:MethodologicalApproach ;
    rdfs:range :FoundationalEntity ;
    owl:inverseOf :isSpecifiedBy .

:suggestion a owl:DatatypeProperty ;
    rdfs:label "suggestion"@en ;
    rdfs:comment "Records a suggested resolution or improvement for an issue"@en ;
    rdfs:domain :IssueEntity ;
    rdfs:range xsd:string .

:supports a owl:ObjectProperty ;
    rdfs:label "supports"@en ;
    rdfs:comment "Relates a tool entity to a language entity that it supports"@en ;
    rdfs:domain :ToolEntity ;
    rdfs:range :LanguageEntity ;
    owl:inverseOf :isSupportedBy .

:uses a owl:ObjectProperty ;
    rdfs:label "uses"@en ;
    rdfs:comment "Relates an ontology entity to another ontology entity that it uses conceptually, methodologically, or technically"@en ;
    rdfs:domain :Entity ;
    rdfs:range :Entity ;
    owl:inverseOf :isUsedBy .

:object a rdf:Property ;
    rdfs:label "object"@en ;
    rdfs:comment "Identifies the object constituent of an issue when the issue concerns a particular assertion; this property designates object role rather than the overall issue target"@en ;
    rdfs:domain :IssueEntity ;
    rdfs:subPropertyOf rdf:object .

:predicate a rdf:Property ;
    rdfs:label "predicate"@en ;
    rdfs:comment "Identifies the predicate constituent of an issue when the issue concerns a particular assertion; this property designates predicate role rather than the overall issue target"@en ;
    rdfs:domain :IssueEntity ;
    rdfs:subPropertyOf rdf:predicate .

:subject a rdf:Property ;
    rdfs:label "subject"@en ;
    rdfs:comment "Identifies the subject constituent of an issue when the issue concerns a particular assertion; this property designates subject role rather than the overall issue target"@en ;
    rdfs:domain :IssueEntity ;
    rdfs:subPropertyOf rdf:subject .

:target a rdf:Property ;
    rdfs:label "target"@en ;
    rdfs:comment "Identifies the primary resource that an issue is about, such as a reviewed resource or an ontology/module addressed as a whole; assertion-level issues are instead designated through subject, predicate, and object"@en ;
    rdfs:domain :IssueEntity .

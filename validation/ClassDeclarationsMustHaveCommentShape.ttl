@prefix ve:   <http://www.softlang.org/ontologies/ve#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

ve:ClassDeclarationsMustHaveCommentShape
  a sh:NodeShape ;

  # target all classes directly
  sh:targetClass owl:Class ;

  # enforce comment exists
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:message "Class declaration is missing an rdfs:comment." ;
  ] .
